{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "bash .github/hooks/setup.sh",
        "powershell": "powershell -File .github\\hooks\\setup.ps1",
        "timeoutSec": 120
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "python3 .github/hooks/validators/post_tool_validator.py",
        "powershell": "python .github\\hooks\\validators\\post_tool_validator.py",
        "timeoutSec": 60
      }
    ]
  }
}
